# ─────────────────────────────────────────────────────────────
# .env.example — Variables d'environnement pour Render
# ─────────────────────────────────────────────────────────────
# Copier ce fichier en tant que `.env` et remplir avec vos valeurs
# NE PAS commiter `.env` (il contient des secrets !)

# Base de données PostgreSQL (fournie par Render)
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_USER=your_postgres_user
DB_PASSWORD=your_postgres_password
DB_DRIVER=org.postgresql.Driver

# Hibernate
JPA_DIALECT=org.hibernate.dialect.PostgreSQL10Dialect

# Port (Render l'injecte automatiquement, ne pas modifier)
PORT=8080
